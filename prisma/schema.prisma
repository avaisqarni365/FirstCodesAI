generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==================== AUTH & USERS ====================

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  role          Role      @default(SALES)
  avatar        String?
  phone         String?
  title         String?
  department    String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  contacts      Contact[]
  deals         Deal[]
  activities    Activity[]
  emails        Email[]
  invoices      Invoice[]
  callLogs      CallLog[]
  teamProfile   TeamProfile?
  campaigns     Campaign[]
}

enum Role {
  ADMIN
  MANAGER
  HR
  SALES
  DEVELOPER
}

// ==================== CRM ====================

model Contact {
  id            String        @id @default(cuid())
  firstName     String
  lastName      String
  email         String?
  phone         String?
  company       String?
  jobTitle      String?
  source        String?
  status        ContactStatus @default(LEAD)
  notes         String?
  tags          String[]
  customFields  Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  ownerId       String
  owner         User          @relation(fields: [ownerId], references: [id])
  companyRef    Company?      @relation(fields: [companyId], references: [id])
  companyId     String?
  deals         Deal[]
  activities    Activity[]
  emails        Email[]
  whatsappChats WhatsAppChat[]
}

enum ContactStatus {
  LEAD
  PROSPECT
  QUALIFIED
  CUSTOMER
  CHURNED
  INACTIVE
}

model Deal {
  id            String    @id @default(cuid())
  title         String
  value         Decimal   @db.Decimal(12, 2)
  currency      String    @default("GBP")
  stage         DealStage @default(DISCOVERY)
  probability   Int       @default(10)
  expectedClose DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  ownerId       String
  owner         User      @relation(fields: [ownerId], references: [id])
  contactId     String
  contact       Contact   @relation(fields: [contactId], references: [id])
  companyId     String?
  company       Company?  @relation(fields: [companyId], references: [id])
  activities    Activity[]
}

enum DealStage {
  DISCOVERY
  QUALIFICATION
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

model Activity {
  id            String       @id @default(cuid())
  type          ActivityType
  subject       String
  description   String?
  date          DateTime     @default(now())
  duration      Int?
  createdAt     DateTime     @default(now())

  userId        String
  user          User         @relation(fields: [userId], references: [id])
  contactId     String?
  contact       Contact?     @relation(fields: [contactId], references: [id])
  dealId        String?
  deal          Deal?        @relation(fields: [dealId], references: [id])
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  NOTE
  TASK
  WHATSAPP
}

// ==================== COMPANIES / HR LEADS ====================

model Company {
  id                 String               @id @default(cuid())
  name               String
  registrationNumber String?
  website            String?
  industry           String?
  size               String?
  address            String?
  city               String?
  country            String               @default("UK")
  phone              String?
  email              String?
  linkedinUrl        String?
  description        String?
  source             String?
  pipelineStage      CompanyPipelineStage @default(IDENTIFIED)
  tags               String[]
  customFields       Json?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  contacts           Contact[]
  deals              Deal[]
  emails             Email[]
}

enum CompanyPipelineStage {
  IDENTIFIED
  RESEARCHING
  CONTACTED
  RESPONDING
  MEETING_SCHEDULED
  PROPOSAL_SENT
  NEGOTIATING
  WON
  LOST
  NURTURING
}

// ==================== EMAIL MARKETING ====================

model EmailAccount {
  id          String  @id @default(cuid())
  email       String  @unique
  displayName String
  smtpHost    String
  smtpPort    Int     @default(587)
  imapHost    String?
  imapPort    Int?    @default(993)
  username    String
  password    String
  isDefault   Boolean @default(false)
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  emails      Email[]
}

model Email {
  id            String         @id @default(cuid())
  subject       String
  body          String
  bodyHtml      String?
  from          String
  to            String[]
  cc            String[]
  bcc           String[]
  status        EmailStatus    @default(DRAFT)
  direction     EmailDirection
  isAiGenerated Boolean        @default(false)
  aiPrompt      String?
  threadId      String?
  messageId     String?
  sentAt        DateTime?
  receivedAt    DateTime?
  openedAt      DateTime?
  repliedAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  userId        String
  user          User           @relation(fields: [userId], references: [id])
  contactId     String?
  contact       Contact?       @relation(fields: [contactId], references: [id])
  companyId     String?
  company       Company?       @relation(fields: [companyId], references: [id])
  accountId     String?
  account       EmailAccount?  @relation(fields: [accountId], references: [id])
  campaignId    String?
  campaign      Campaign?      @relation(fields: [campaignId], references: [id])
}

enum EmailStatus {
  DRAFT
  QUEUED
  SENT
  DELIVERED
  OPENED
  REPLIED
  BOUNCED
  FAILED
}

enum EmailDirection {
  INBOUND
  OUTBOUND
}

model Campaign {
  id           String         @id @default(cuid())
  name         String
  subject      String
  bodyTemplate String
  status       CampaignStatus @default(DRAFT)
  scheduledAt  DateTime?
  sentCount    Int            @default(0)
  openCount    Int            @default(0)
  replyCount   Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  userId       String
  user         User           @relation(fields: [userId], references: [id])
  emails       Email[]
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  PAUSED
  CANCELLED
}

// ==================== COMMUNICATIONS ====================

model WhatsAppChat {
  id            String    @id @default(cuid())
  phoneNumber   String
  contactName   String?
  lastMessage   String?
  lastMessageAt DateTime?
  unreadCount   Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  contactId     String?
  contact       Contact?  @relation(fields: [contactId], references: [id])
  messages      WhatsAppMessage[]
}

model WhatsAppMessage {
  id        String           @id @default(cuid())
  body      String
  direction MessageDirection
  status    String?
  mediaUrl  String?
  timestamp DateTime         @default(now())

  chatId    String
  chat      WhatsAppChat     @relation(fields: [chatId], references: [id])
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

model CallLog {
  id          String        @id @default(cuid())
  phoneNumber String
  contactName String?
  direction   CallDirection
  status      CallStatus
  duration    Int?
  recording   String?
  notes       String?
  startedAt   DateTime
  endedAt     DateTime?
  createdAt   DateTime      @default(now())

  userId      String
  user        User          @relation(fields: [userId], references: [id])
}

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum CallStatus {
  RINGING
  IN_PROGRESS
  COMPLETED
  MISSED
  VOICEMAIL
  FAILED
}

// ==================== ACCOUNTING ====================

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  clientName    String
  clientEmail   String?
  clientAddress String?
  issueDate     DateTime      @default(now())
  dueDate       DateTime
  status        InvoiceStatus @default(DRAFT)
  subtotal      Decimal       @db.Decimal(12, 2)
  vatRate       Decimal       @db.Decimal(5, 2) @default(20)
  vatAmount     Decimal       @db.Decimal(12, 2)
  total         Decimal       @db.Decimal(12, 2)
  currency      String        @default("GBP")
  notes         String?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  userId        String
  user          User          @relation(fields: [userId], references: [id])
  items         InvoiceItem[]
}

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PAID
  OVERDUE
  CANCELLED
}

model InvoiceItem {
  id          String  @id @default(cuid())
  description String
  quantity    Decimal @db.Decimal(10, 2)
  unitPrice   Decimal @db.Decimal(12, 2)
  total       Decimal @db.Decimal(12, 2)

  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Expense {
  id          String        @id @default(cuid())
  description String
  amount      Decimal       @db.Decimal(12, 2)
  currency    String        @default("GBP")
  category    String
  date        DateTime
  receipt     String?
  vendor      String?
  status      ExpenseStatus @default(PENDING)
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
  REIMBURSED
}

// ==================== WEBSITE CONTENT (ADMIN PORTAL) ====================

model WebPage {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  content         Json
  metaTitle       String?
  metaDescription String?
  isPublished     Boolean  @default(false)
  publishedAt     DateTime?
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Service {
  id          String   @id @default(cuid())
  title       String
  description String
  icon        String?
  features    String[]
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Testimonial {
  id            String   @id @default(cuid())
  clientName    String
  clientTitle   String?
  clientCompany String?
  content       String
  rating        Int      @default(5)
  avatar        String?
  isPublished   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  type      String   @default("text")
  group     String   @default("general")
  updatedAt DateTime @updatedAt
}

// ==================== TEAM HUB ====================

model TeamProfile {
  id              String   @id @default(cuid())
  bio             String?
  skills          String[]
  specializations String[]
  linkedinUrl     String?
  githubUrl       String?
  portfolioUrl    String?
  availability    String?  @default("available")
  isPublic        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
}

model AITool {
  id           String   @id @default(cuid())
  name         String
  description  String
  category     String
  website      String?
  logo         String?
  isIntegrated Boolean  @default(false)
  apiKey       String?
  config       Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
